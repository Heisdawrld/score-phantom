# ScorePhantom v2 — Environment Variables
# Copy to .env locally. Set all values in Render dashboard for production.
# NEVER commit .env to git.

# ── Database ────────────────────────────────────────────────────────────────
TURSO_URL=libsql://your-database.turso.io
TURSO_TOKEN=your_turso_auth_token

# ── Auth ───────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=your_strong_random_jwt_secret_here

# ── Admin ──────────────────────────────────────────────────────────────────
ADMIN_EMAIL=your_admin_email@example.com
ADMIN_SECRET=your_strong_admin_secret

# ── External APIs ───────────────────────────────────────────────────────────
LIVESCORE_API_KEY=your_livescore_api_key
LIVESCORE_API_SECRET=your_livescore_api_secret
GROQ_API_KEY=your_groq_api_key
ODDS_API_KEY=your_odds_api_key_optional

# ── Flutterwave Payment ─────────────────────────────────────────────────────────
# Get from: dashboard.flutterwave.com → Settings → API Keys
# Use LIVE keys in production (not test -X keys)
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_ENCRYPTION_KEY=your_encryption_key
# Set this in Flutterwave dashboard under Webhooks → Secret Hash
FLUTTERWAVE_WEBHOOK_HASH=your_webhook_secret_hash

# ── App ──────────────────────────────────────────────────────────────────────
APP_URL=https://your-app.onrender.com
PORT=3000
NODE_ENV=production
