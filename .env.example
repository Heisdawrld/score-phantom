# ScorePhantom v2 — Environment Variables
# Copy to .env locally. Set all values in Render dashboard for production.
# NEVER commit .env to git.

# ── Database (Turso / libSQL) ──────────────────────────────────────────────────
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# ── Auth ───────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=your_strong_random_jwt_secret_here

# ── Admin ──────────────────────────────────────────────────────────────────
ADMIN_EMAIL=your_admin_email@example.com
ADMIN_SECRET=your_strong_admin_secret

# ── External APIs ───────────────────────────────────────────────────────────
BSD_API_KEY=your_bzzoiro_api_key_here
LIVESCORE_API_KEY=your_livescore_api_key
LIVESCORE_API_SECRET=your_livescore_api_secret
GROQ_API_KEY=your_groq_api_key

# ── Flutterwave Payment ─────────────────────────────────────────────────────
FLUTTERWAVE_PUBLIC_KEY=your_flutterwave_public_key
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key
FLUTTERWAVE_ENCRYPTION_KEY=your_encryption_key
# Set this in Flutterwave dashboard under Webhooks → Secret Hash
FLUTTERWAVE_WEBHOOK_HASH=your_webhook_secret_hash

# ── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=ScorePhantom <noreply@score-phantom.onrender.com>

# ── App ──────────────────────────────────────────────────────────────────────
APP_URL=https://your-app.onrender.com
PORT=3000
NODE_ENV=production
